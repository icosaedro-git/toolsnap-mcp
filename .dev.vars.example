# x402 payment configuration.
# Copy this file to .dev.vars and fill in real values for local development.
X402_PAY_TO_ADDRESS=0xYourPublicWalletAddressHere
X402_NETWORK=base

# Admin bypass key — allows calling paid tools without payment (set via: wrangler secret put ADMIN_API_KEY)
ADMIN_API_KEY=your-secret-admin-key-here

# Comma-separated EVM addresses whitelisted for free access (relay wallet public address)
WHITELISTED_ADDRESSES=0xYourRelayWalletPublicAddressHere

# screenshot_url (Fase 11.2): ScreenshotOne access key for the production provider.
# Optional — if unset, screenshot_url uses the keyless microlink free-tier provider.
# Set in production via: wrangler secret put SCREENSHOT_API_KEY
SCREENSHOT_API_KEY=your-screenshotone-access-key-here

# Fase 22.1 — ToolSnap X Agent (local dev / e2e). In production set via
# wrangler secret put <NAME> for each — see wrangler.jsonc's secrets comment.
X_API_KEY=your-x-app-consumer-key
X_API_SECRET=your-x-app-consumer-secret
X_ACCESS_TOKEN_PRODUCT=oauth1-access-token-for-toolsnapmcp
X_ACCESS_TOKEN_SECRET_PRODUCT=oauth1-access-token-secret-for-toolsnapmcp
X_ACCESS_TOKEN_PERSONAL=oauth1-access-token-for-icosaedro_one
X_ACCESS_TOKEN_SECRET_PERSONAL=oauth1-access-token-secret-for-icosaedro_one
X_USER_ID_PRODUCT=numeric-x-user-id-for-toolsnapmcp
X_USER_ID_PERSONAL=numeric-x-user-id-for-icosaedro_one
# "1" makes the publisher log instead of calling the real X API — use this
# for local/e2e testing (scripts/x-agent-test.mts sets it automatically).
X_DRY_RUN=1
X_TG_BOT_TOKEN=your-dedicated-x-agent-telegram-bot-token
X_TG_WEBHOOK_SECRET=any-random-string-also-passed-to-setWebhook
# Shared with the alerts bot's chat — needed locally so
# scripts/x-agent-test.mts can simulate a Telegram callback_query (veto
# cancel button) against /webhooks/telegram.
TELEGRAM_CHAT_ID=123456789

# Fase 22.2 — L2 veto window. Kept short here so scripts/x-agent-test.mts can
# exercise the "not yet eligible" and "window satisfied" cases within a few
# seconds. Production uses the wrangler.jsonc defaults (14400/1800 = 4h/30min).
X_VETO_NOTICE_S=14400
X_VETO_MIN_S=6
