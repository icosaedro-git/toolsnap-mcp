---
interface Props {
  id: string;
  label: string;
  oneLiner: string;
  toolCount: number;
  freeCount: number;
}
const { id, label, oneLiner, toolCount, freeCount } = Astro.props;
---

<a href={`/tools#${id}`} class="family-card card reveal">
  <h3>{label}</h3>
  <p class="count mono">{toolCount} tools &middot; {freeCount} free</p>
  <p class="blurb">{oneLiner}</p>
</a>

<style>
  .family-card { display: block; }
  .family-card h3 { font-size: 1.05rem; margin-bottom: 8px; }
  .family-card .count { font-size: 0.78rem; color: var(--lime); margin-bottom: 10px; }
  .family-card .blurb { color: var(--text-soft); font-size: 0.92rem; line-height: 1.55; }
</style>
