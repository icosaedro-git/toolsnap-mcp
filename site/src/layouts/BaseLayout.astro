---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  path?: string;
}

const { title, description, path = Astro.url.pathname } = Astro.props;
const canonical = new URL(path, Astro.site).toString();
const ogImage = new URL('/img/og-default.png', Astro.site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <link rel="icon" href="/img/favicon-32.png" sizes="32x32" type="image/png" />
    <link rel="apple-touch-icon" href="/img/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#0B0E14" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <slot name="head" />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <script src="../scripts/client.js"></script>
    <!--
      Cloudflare Web Analytics (Fase 21.1). Cookie-free, no consent banner
      needed. The token below is a PLACEHOLDER — our API token has no
      analytics scope, so this couldn't be provisioned automatically.
      To activate: Cloudflare dashboard -> Analytics & Logs -> Web Analytics
      -> Add a site -> mcp.toolsnap.app -> copy the "token" value from the
      generated snippet and paste it in place of REPLACE_WITH_CF_BEACON_TOKEN
      below (one line, no code changes needed elsewhere).
    -->
    <script
      defer
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon='{"token": "REPLACE_WITH_CF_BEACON_TOKEN"}'
    ></script>
  </body>
</html>
