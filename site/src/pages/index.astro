---
import BaseLayout from '../layouts/BaseLayout.astro';
import CodeBlock from '../components/CodeBlock.astro';
import FamilyCard from '../components/FamilyCard.astro';
import RecipeCard from '../components/RecipeCard.astro';
import families from '../data/families.json';
import recipes from '../data/recipes.json';
import toolsData from '../data/tools.json';

const title = 'ToolSnap MCP — One connection. Superpowers for your agent.';
const description =
  '38 server-side tools for AI agents through a single MCP connection. 35 free, no new accounts. Median 98.1% token savings on web content. Paid tools from $0.02.';
---

<BaseLayout title={title} description={description}>
  <!-- ═══════════════ HERO ═══════════════ -->
  <section class="hero section section--ink">
    <svg class="hero-lines" viewBox="0 0 1120 700" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
      <path d="M-20,60 C 200,100 380,220 560,340" fill="none" stroke="#232B36" stroke-width="1" opacity="0.5"/>
      <path d="M-20,160 C 220,180 380,260 560,360" fill="none" stroke="#232B36" stroke-width="1" opacity="0.5"/>
      <path d="M-20,260 C 220,260 400,320 560,380" fill="none" stroke="#232B36" stroke-width="1" opacity="0.5"/>
      <path d="M-20,420 C 220,400 400,400 560,400" fill="none" stroke="#232B36" stroke-width="1" opacity="0.5"/>
      <path d="M-20,520 C 220,460 400,420 560,410" fill="none" stroke="#232B36" stroke-width="1" opacity="0.5"/>
      <path d="M-20,600 C 220,500 400,440 560,410" fill="none" stroke="#232B36" stroke-width="1" opacity="0.5"/>
    </svg>

    <div class="container hero-grid">
      <div class="hero-text">
        <p class="eyebrow mono">MCP SERVER &middot; {toolsData.total} TOOLS &middot; LIVE</p>
        <h1 class="h-hero">One connection.<br /><span class="lime">Superpowers for your agent.</span></h1>
        <p class="hero-sub">
          ToolSnap gives any MCP-capable agent {toolsData.total} server-side tools — web extraction, SEO, documents, data, images. {toolsData.free} are free. Zero new accounts. Your agent's context window stays clean, and your bill stays small.
        </p>
        <div class="hero-cta">
          <a href="#connect" class="btn btn--primary">Connect in 30 seconds</a>
          <a href="/tools" class="btn btn--ghost">Browse the tools</a>
        </div>

        <div class="stat-strip">
          <div class="stat-item">
            <p class="stat-num">98.1%</p>
            <p class="stat-label text-mute">median token savings on web content</p>
          </div>
          <div class="stat-item">
            <p class="stat-num">{toolsData.free} / {toolsData.total}</p>
            <p class="stat-label text-mute">tools free to call</p>
          </div>
          <div class="stat-item">
            <p class="stat-num">$0</p>
            <p class="stat-label text-mute">accounts, subscriptions or sign-ups required</p>
          </div>
        </div>
        <p class="hero-caption text-mute">
          Benchmark: fetch_extract turns a 53,820-token page into 2,001 tokens. That's ~$0.156 saved on a single Sonnet call — more than most paid tools here cost.
        </p>
      </div>

      <div class="hero-visual">
        <div class="hero-glow" aria-hidden="true"></div>
        <div class="hero-video-mask">
          <video
            data-hero-video
            src="/img/logo-loop.mp4"
            poster="/img/logo-loop-poster.jpg"
            muted
            loop
            playsinline
            autoplay
            preload="metadata"
            aria-hidden="true"
          >
            <source src="/img/logo-loop.webm" type="video/webm" />
            <source src="/img/logo-loop.mp4" type="video/mp4" />
          </video>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════ PROBLEM ═══════════════ -->
  <section class="section section--ink2">
    <div class="container section-head reveal">
      <p class="eyebrow mono">WHY IT EXISTS</p>
      <h2 class="h-section">Your agent's most expensive resource isn't compute. It's context.</h2>
      <p class="lead">
        Every raw webpage, PDF or CSV your agent loads gets re-sent with every turn of the conversation. That's how a "quick look at a URL" quietly becomes the biggest line on your API bill. ToolSnap tools work by reference: the server fetches, parses and filters the heavy data, and returns only the small, clean result. The raw input never touches your agent's context window.
      </p>
    </div>
    <div class="container problem-grid">
      <div class="mini-card card reveal">
        <svg class="mini-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 12h11M11 6l6 6-6 6"/><rect x="17" y="4" width="4" height="16" rx="1"/></svg>
        <h3>By reference, not by value</h3>
        <p>Point a tool at a URL or file. It returns the answer, not the payload.</p>
      </div>
      <div class="mini-card card reveal">
        <svg class="mini-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M5 12l4-4M5 12l4 4M19 12l-4-4M19 12l-4 4"/></svg>
        <h3>Deterministic results</h3>
        <p>Parsers, not vibes: same input, same output, every time.</p>
      </div>
      <div class="mini-card card reveal">
        <svg class="mini-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="4" y="3" width="16" height="6" rx="1"/><rect x="4" y="10" width="16" height="6" rx="1"/><rect x="4" y="17" width="16" height="4" rx="1"/></svg>
        <h3>Server-side muscle</h3>
        <p>Headless rendering, ML models and heavy parsing your agent's sandbox doesn't have.</p>
      </div>
    </div>
  </section>

  <!-- ═══════════════ CONNECT ═══════════════ -->
  <section class="section connect-section" id="connect">
    <div class="container section-head reveal">
      <p class="eyebrow mono">GET STARTED</p>
      <h2 class="h-section">Connect in 30 seconds. Pay only if you want the paid three.</h2>
      <p class="lead">One URL. No API key needed for the {toolsData.free} free tools.</p>
    </div>

    <div class="container">
      <div class="tabs-outer reveal" data-tabs>
        <div class="tabs" role="tablist">
          <button class="tab-btn" role="tab" aria-selected="true" data-tab-target="free">Free — just the URL</button>
          <button class="tab-btn" role="tab" aria-selected="false" data-tab-target="paid">Paid — credits or crypto</button>
        </div>

        <div class="tab-panel" role="tabpanel" data-tab-panel="free">
          <CodeBlock lang="bash" code={`claude mcp add --transport http toolsnap https://mcp.toolsnap.app/mcp`} />
          <div class="client-switcher mono">
            <span>Claude Desktop / claude.ai:</span> <code class="inline">Add a custom connector with URL https://mcp.toolsnap.app/mcp</code>
          </div>
          <CodeBlock lang="json" code={`{ "mcpServers": { "toolsnap": { "url": "https://mcp.toolsnap.app/mcp" } } }`} />
          <p class="caption text-mute">That's it. Your agent now has {toolsData.free} free tools. Ask it to call tool_catalog to see everything.</p>
        </div>

        <div class="tab-panel" role="tabpanel" data-tab-panel="paid" hidden>
          <p class="paid-intro text-soft">Three tools have real per-call costs (screenshots, keyword data, background removal). Pay per call from $0.02 — two rails, pick one:</p>
          <div class="paid-cards">
            <div class="card">
              <h3>Card &rarr; credits (no crypto)</h3>
              <p class="text-soft">Buy credits with a card ($5 minimum), get an API key, done.</p>
              <CodeBlock lang="bash" code={`claude mcp add --transport http toolsnap https://mcp.toolsnap.app/mcp --header "Authorization: Bearer sk_live_…"`} />
              <p class="text-mute small">Clients that can't set headers can embed the key in the URL: <code class="inline">https://mcp.toolsnap.app/mcp/sk_live_…</code></p>
              <a href="/checkout" class="btn btn--ghost btn--sm">Get credits &rarr;</a>
            </div>
            <div class="card">
              <h3>Crypto (x402) — agent pays autonomously</h3>
              <p class="text-soft">Give your agent its own wallet with a few USDC on Base. It pays per call, no account at all.</p>
              <a href="/wallet-guide" class="btn btn--ghost btn--sm">Wallet guide &rarr;</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════ TOOLS OVERVIEW ═══════════════ -->
  <section class="section section--ink">
    <div class="container section-head reveal">
      <p class="eyebrow mono">THE CATALOG</p>
      <h2 class="h-section">{toolsData.total} tools. One list your agent actually reads.</h2>
      <p class="lead">Your agent sees a curated core of {toolsData.coreCount} tools on first connection (~1.6k tokens — most MCP servers burn 10&times; that). The full catalog is one tool_catalog call away.</p>
    </div>
    <div class="container family-grid">
      {families.map((f: any) => (
        <FamilyCard id={f.id} label={f.label} oneLiner={f.oneLiner} toolCount={f.toolCount} freeCount={f.freeCount} />
      ))}
    </div>
    <div class="container cta-center reveal">
      <a href="/tools" class="btn btn--ghost">See all {toolsData.total} tools with prices &rarr;</a>
    </div>
  </section>

  <!-- ═══════════════ RECIPES ═══════════════ -->
  <section class="section section--ink2">
    <div class="container section-head reveal">
      <p class="eyebrow mono">RECIPES</p>
      <h2 class="h-section">Don't orchestrate. Hand your agent a recipe.</h2>
      <p class="lead">A recipe is a ready-made multi-tool plan your agent can execute end-to-end: which tools, in what order, with cost estimates. Served by the free task_recipes tool — or copy the prompt from here.</p>
    </div>
    <div class="container recipe-grid">
      {recipes.map((r: any) => (
        <RecipeCard title={r.title} summary={r.summary} audience={r.audience} tools={r.tools} estCost={r.est_cost} prompt={r.prompt} />
      ))}
    </div>
    <div class="container cta-center reveal">
      <a href="/recipes" class="btn btn--ghost">Browse recipes &rarr;</a>
    </div>
  </section>

  <!-- ═══════════════ PRICING SUMMARY ═══════════════ -->
  <section class="section section--ink">
    <div class="container section-head reveal">
      <p class="eyebrow mono">PRICING</p>
      <h2 class="h-section">Free is the product. Paid is the exception.</h2>
    </div>
    <div class="container pricing-grid">
      <div class="price-col card reveal">
        <p class="price-tier">Free</p>
        <p class="price-big mono">$0</p>
        <p class="text-soft">{toolsData.free} tools, unlimited calls. No account, no key, no catch — free tools are how ToolSnap becomes your agent's habit.</p>
      </div>
      <div class="price-col price-col--highlight card reveal">
        <p class="price-tier">Credits</p>
        <p class="price-big mono">from $5</p>
        <p class="text-soft">Card checkout via Polar. Credits never expire. Paid tools cost $0.02–$0.025 per call on credits.</p>
      </div>
      <div class="price-col card reveal">
        <p class="price-tier">Pay-per-call (x402)</p>
        <p class="price-big mono">from $0.02</p>
        <p class="text-soft">USDC on Base, settled on-chain per call. No account — your agent pays autonomously.</p>
      </div>
    </div>
    <div class="container cta-center reveal">
      <a href="/pricing" class="btn btn--ghost">Full pricing &rarr;</a>
    </div>
  </section>

  <!-- ═══════════════ TRUST ═══════════════ -->
  <section class="section section--ink2">
    <div class="container section-head reveal">
      <h2 class="h-section">Built like infrastructure, not a demo.</h2>
    </div>
    <div class="container trust-grid">
      <div class="trust-item reveal">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 2 4 6v6c0 5 3.5 8.5 8 10 4.5-1.5 8-5 8-10V6l-8-4Z"/><path d="m9 12 2 2 4-4"/></svg>
        <p>We never see private keys. Agent wallets are generated and stored on your machine — we only ever receive signatures.</p>
      </div>
      <div class="trust-item reveal">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 2 4 6v6c0 5 3.5 8.5 8 10 4.5-1.5 8-5 8-10V6l-8-4Z"/><path d="m9 12 2 2 4-4"/></svg>
        <p>Card payments are handled by Polar (Merchant of Record). Card data never touches our servers.</p>
      </div>
      <div class="trust-item reveal">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 2 4 6v6c0 5 3.5 8.5 8 10 4.5-1.5 8-5 8-10V6l-8-4Z"/><path d="m9 12 2 2 4-4"/></svg>
        <p>API keys are stored hashed, shown once, revocable any time.</p>
      </div>
      <div class="trust-item reveal">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 2 4 6v6c0 5 3.5 8.5 8 10 4.5-1.5 8-5 8-10V6l-8-4Z"/><path d="m9 12 2 2 4-4"/></svg>
        <p>Every tool is deterministic and stateless: we process your URLs and inputs, return the result, and keep only usage metadata.</p>
      </div>
    </div>
  </section>

  <!-- ═══════════════ FINAL CTA ═══════════════ -->
  <section class="section final-cta">
    <div class="container reveal">
      <h2 class="h-section">Give your agent superpowers today.</h2>
      <p class="lead">One URL. {toolsData.free} free tools. Your context window will thank you.</p>
      <div class="endpoint-pill mono">
        <span id="final-endpoint">https://mcp.toolsnap.app/mcp</span>
        <button class="copy-btn" data-copy-target="#final-endpoint" aria-label="Copy to clipboard">
          <svg class="icon-copy" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="12" height="12" rx="2"/><path d="M5 15H4a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h10a1 1 0 0 1 1 1v1"/></svg>
          <svg class="icon-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6 9 17l-5-5"/></svg>
          <span class="copy-btn-label label-copy">Copy</span>
          <span class="copy-btn-label label-copied">Copied</span>
        </button>
      </div>
      <a href="#connect" class="btn btn--primary">Connect free</a>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Hero ── */
  .hero {
    position: relative;
    min-height: calc(100svh - 68px);
    display: flex;
    align-items: center;
    overflow: hidden;
    padding-block: 64px;
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 40% at 75% 20%, rgba(45, 80, 22, 0.12), transparent);
    pointer-events: none;
  }
  .hero-lines {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }
  .hero-grid {
    position: relative;
    display: grid;
    grid-template-columns: 55% 45%;
    gap: 40px;
    align-items: center;
  }
  .hero-text { max-width: 560px; }
  .hero-sub { color: var(--text-soft); max-width: 520px; margin-top: 22px; font-size: 1.05rem; line-height: 1.65; }
  .hero-cta { display: flex; gap: 16px; margin-top: 32px; flex-wrap: wrap; }

  .stat-strip {
    display: flex;
    gap: 0;
    margin-top: 56px;
  }
  .stat-item {
    padding-right: 28px;
    margin-right: 28px;
    border-right: 1px solid var(--border);
  }
  .stat-item:last-child { border-right: none; margin-right: 0; padding-right: 0; }
  .stat-label { font-size: 0.85rem; margin-top: 6px; max-width: 140px; }
  .hero-caption { font-size: 0.8rem; max-width: 560px; margin-top: 20px; }

  .hero-visual {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 380px;
  }
  .hero-glow {
    position: absolute;
    width: 130%;
    aspect-ratio: 1;
    background: radial-gradient(circle, var(--lime-glow), transparent 65%);
    animation: glowDrift 14s ease-in-out infinite alternate;
  }
  @keyframes glowDrift {
    0% { transform: translate(-2%, -1%) scale(1); opacity: 0.7; }
    100% { transform: translate(2%, 2%) scale(1.06); opacity: 1; }
  }
  .hero-video-mask {
    position: relative;
    width: min(38vw, 460px);
    aspect-ratio: 1;
    border-radius: 50%;
    overflow: hidden;
    -webkit-mask-image: radial-gradient(circle, black 58%, transparent 72%);
    mask-image: radial-gradient(circle, black 58%, transparent 72%);
  }
  .hero-video-mask video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-glow { animation: none; }
  }

  @media (max-width: 980px) {
    .hero-grid { grid-template-columns: 1fr; text-align: center; }
    .hero-text { max-width: 640px; margin-inline: auto; }
    .hero-sub { margin-inline: auto; }
    .hero-cta { justify-content: center; }
    .stat-strip { justify-content: center; }
    .hero-caption { margin-inline: auto; }
    .hero-visual { order: -1; min-height: 260px; }
    .hero-video-mask { width: 220px; }
  }

  /* ── Problem ── */
  .problem-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .mini-card { text-align: left; }
  .mini-icon { width: 24px; height: 24px; color: var(--lime); margin-bottom: 16px; }
  .mini-card h3 { font-size: 1.05rem; margin-bottom: 8px; }
  .mini-card p { color: var(--text-soft); font-size: 0.92rem; }
  @media (max-width: 760px) { .problem-grid { grid-template-columns: 1fr; } }

  /* ── Connect ── */
  .connect-section { background: var(--ink-2); position: relative; }
  .connect-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 50% 30% at 50% 0%, var(--lime-glow), transparent);
    opacity: 0.6;
    pointer-events: none;
  }
  .tabs-outer { position: relative; }
  .tab-panel { margin-top: 28px; }
  .client-switcher { margin-block: 16px; font-size: 0.85rem; color: var(--text-soft); }
  .caption { margin-top: 16px; font-size: 0.88rem; }
  .paid-intro { margin-bottom: 24px; }
  .paid-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .paid-cards h3 { font-size: 1.05rem; margin-bottom: 10px; }
  .paid-cards p { margin-bottom: 14px; }
  .paid-cards .small { font-size: 0.8rem; margin-top: -4px; }
  @media (max-width: 860px) { .paid-cards { grid-template-columns: 1fr; } }

  /* ── Family grid ── */
  .family-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-bottom: 40px;
  }
  @media (max-width: 980px) { .family-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .family-grid { grid-template-columns: 1fr; } }
  .cta-center { text-align: center; }

  /* ── Recipes ── */
  .recipe-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 40px;
  }
  @media (max-width: 860px) { .recipe-grid { grid-template-columns: 1fr; } }

  /* ── Pricing ── */
  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 40px;
  }
  .price-col { text-align: left; }
  .price-tier { font-family: var(--font-mono); font-size: 0.85rem; color: var(--text-soft); margin-bottom: 10px; }
  .price-big { font-size: 2rem; color: var(--head); margin-bottom: 14px; }
  .price-col--highlight { border-color: var(--lime); box-shadow: 0 0 40px -20px var(--lime-glow); }
  .price-col--highlight .price-big { color: var(--lime); }
  @media (max-width: 860px) { .pricing-grid { grid-template-columns: 1fr; } }

  /* ── Trust ── */
  .trust-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    max-width: 800px;
    margin-inline: auto;
  }
  .trust-item { display: flex; gap: 14px; align-items: flex-start; }
  .trust-item svg { width: 22px; height: 22px; color: var(--lime); flex-shrink: 0; margin-top: 2px; }
  .trust-item p { color: var(--text-soft); font-size: 0.95rem; line-height: 1.6; }
  @media (max-width: 600px) { .trust-grid { grid-template-columns: 1fr; } }

  /* ── Final CTA ── */
  .final-cta {
    text-align: center;
    position: relative;
    padding-block: calc(var(--sect-y) * 1.2);
  }
  .final-cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 50% 60% at 50% 50%, var(--lime-glow), transparent);
    opacity: 0.5;
    pointer-events: none;
  }
  .final-cta .lead { color: var(--text-soft); margin-top: 16px; margin-bottom: 36px; }
  .endpoint-pill {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    background: var(--surface-2);
    border: 1px solid var(--border-strong);
    border-radius: var(--r-pill);
    padding: 14px 10px 14px 24px;
    font-size: 0.95rem;
    color: var(--head);
    margin-bottom: 32px;
    position: relative;
    z-index: 1;
  }
  .endpoint-pill .copy-btn { position: static; }
</style>
